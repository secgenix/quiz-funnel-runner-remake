# Telegram Bot Token (получить у @BotFather)
TELEGRAM_BOT_TOKEN=

# Ваш Telegram User ID (можно узнать у @userinfobot)
TELEGRAM_ADMIN_ID=

# Google Drive OAuth 2.0 credentials file path
GOOGLE_DRIVE_CREDENTIALS_FILE=client_secret.json

# Enable or disable Google Drive integration
GOOGLE_DRIVE_ENABLED=false

# File for stored OAuth token
GOOGLE_DRIVE_TOKEN_FILE=token.json

# Google Drive Folder ID для загрузки файлов (опционально)
GOOGLE_DRIVE_FOLDER_ID=

# If Folder ID is empty, uploader will create or reuse this root folder automatically
GOOGLE_DRIVE_ROOT_FOLDER_NAME=Quiz Funnel Runner Results

# OpenAI API key for AI fallback
OPENAI_API_KEY=
